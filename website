<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AI Aerospace Decision Tool</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
      font-family: Arial, sans-serif;
    }

    body {
      background: #0f172a;
      color: #e5e7eb;
      line-height: 1.6;
    }

    header {
      padding: 70px 10%;
      background: linear-gradient(135deg, #020617, #1e3a8a);
      text-align: center;
    }

    header h1 {
      font-size: 2.8rem;
      margin-bottom: 15px;
    }

    header p {
      max-width: 850px;
      margin: auto;
      font-size: 1.1rem;
      color: #cbd5e1;
    }

    section {
      padding: 50px 10%;
    }

    .card {
      background: #111827;
      border: 1px solid #334155;
      border-radius: 16px;
      padding: 25px;
      margin-bottom: 25px;
      box-shadow: 0 10px 25px rgba(0,0,0,0.25);
    }

    h2 {
      color: #93c5fd;
      margin-bottom: 15px;
    }

    h3 {
      margin-bottom: 10px;
      color: #bfdbfe;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 20px;
    }

    label {
      display: block;
      margin-top: 15px;
      font-weight: bold;
    }

    input {
      width: 100%;
      padding: 10px;
      margin-top: 6px;
      border-radius: 8px;
      border: none;
      background: #1f2937;
      color: #fff;
    }

    button {
      margin-top: 25px;
      padding: 12px 20px;
      border: none;
      border-radius: 10px;
      background: #2563eb;
      color: white;
      font-size: 1rem;
      cursor: pointer;
    }

    button:hover {
      background: #1d4ed8;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 20px;
      overflow-x: auto;
    }

    th, td {
      border-bottom: 1px solid #334155;
      padding: 12px;
      text-align: left;
    }

    th {
      color: #93c5fd;
    }

    .highlight {
      color: #22c55e;
      font-weight: bold;
    }

    footer {
      text-align: center;
      padding: 30px;
      background: #020617;
      color: #94a3b8;
    }
  </style>
</head>
<body>
  <header>
    <h1>AI Aerospace Decision Tool</h1>
    <p>
      An interactive decision-support website for comparing how artificial intelligence can be applied in aerospace research, aviation, and space mission planning.
    </p>
  </header>

  <section>
    <div class="card">
      <h2>Project Overview</h2>
      <p>
        This tool ranks several aerospace AI applications using a weighted scoring model. The goal is to help students, researchers, and project teams compare possible AI use cases based on practical factors such as impact, risk, complexity, feasibility, cost, and data availability.
      </p>
    </div>

    <div class="grid">
      <div class="card">
        <h3>Satellite Image Analysis</h3>
        <p>Uses AI to classify, detect, and interpret satellite imagery for Earth observation, defense, agriculture, and disaster response.</p>
      </div>
      <div class="card">
        <h3>Aircraft Fault Detection</h3>
        <p>Applies machine learning to maintenance data and sensor readings to predict mechanical issues before failures occur.</p>
      </div>
      <div class="card">
        <h3>Weather Forecasting</h3>
        <p>Improves aviation and mission planning by using AI models to analyze weather patterns and forecast operational conditions.</p>
      </div>
      <div class="card">
        <h3>Autonomous Navigation</h3>
        <p>Supports drones, aircraft, and spacecraft that need to navigate with limited human control in complex environments.</p>
      </div>
      <div class="card">
        <h3>Space Mission Planning</h3>
        <p>Uses AI to optimize mission schedules, trajectories, resource allocation, and decision-making for space exploration.</p>
      </div>
    </div>
  </section>

  <section>
    <div class="card">
      <h2>Interactive Scoring Model</h2>
      <p>Adjust the weights below to decide which factors matter most. Higher weights make that factor more important in the final ranking.</p>

      <div class="grid">
        <div>
          <label>Impact Weight</label>
          <input id="impactWeight" type="number" step="0.1" value="2.0">
        </div>
        <div>
          <label>Risk Weight</label>
          <input id="riskWeight" type="number" step="0.1" value="1.2">
        </div>
        <div>
          <label>Complexity Weight</label>
          <input id="complexityWeight" type="number" step="0.1" value="0.8">
        </div>
        <div>
          <label>Feasibility Weight</label>
          <input id="feasibilityWeight" type="number" step="0.1" value="1.5">
        </div>
        <div>
          <label>Cost Weight</label>
          <input id="costWeight" type="number" step="0.1" value="0.5">
        </div>
        <div>
          <label>Data Availability Weight</label>
          <input id="dataWeight" type="number" step="0.1" value="1.0">
        </div>
      </div>

      <button onclick="calculateScores()">Calculate Ranking</button>

      <h3 style="margin-top:30px;">Recommended Focus Area: <span id="recommendation" class="highlight"></span></h3>

      <table id="resultsTable">
        <thead>
          <tr>
            <th>Rank</th>
            <th>Application</th>
            <th>Impact</th>
            <th>Risk</th>
            <th>Complexity</th>
            <th>Feasibility</th>
            <th>Cost</th>
            <th>Data</th>
            <th>Final Score</th>
          </tr>
        </thead>
        <tbody></tbody>
      </table>
    </div>
  </section>

  <section>
    <div class="card">
      <h2>Final Score Chart</h2>
      <canvas id="scoreChart"></canvas>
    </div>
  </section>

  <section>
    <div class="card">
      <h2>How the Model Works</h2>
      <p>
        The model gives positive value to impact, feasibility, and data availability. It subtracts risk, complexity, and cost because those factors can make a project harder to complete. This is a simplified educational model, not a real aerospace engineering standard.
      </p>
      <p style="margin-top:15px;"><strong>Formula:</strong></p>
      <p>
        Final Score = Impact × Impact Weight − Risk × Risk Weight − Complexity × Complexity Weight + Feasibility × Feasibility Weight − Cost × Cost Weight + Data Availability × Data Weight
      </p>
    </div>

    <div class="card">
      <h2>Limitations</h2>
      <p>
        The scores are manually estimated and are meant for learning, comparison, and presentation purposes. Future versions could use real aerospace datasets, add more AI applications, include safety requirements, and support downloadable reports.
      </p>
    </div>
  </section>

  <footer>
    <p>Created by Louie Alruzouq | AI Aerospace Decision Tool</p>
  </footer>

  <script>
    const apps = [
      { application: "Satellite image analysis", impact: 9, risk: 4, complexity: 7, feasibility: 8, cost: 6, data: 9 },
      { application: "Aircraft fault detection", impact: 8, risk: 5, complexity: 8, feasibility: 7, cost: 7, data: 7 },
      { application: "Weather forecasting", impact: 9, risk: 4, complexity: 8, feasibility: 7, cost: 6, data: 8 },
      { application: "Autonomous navigation", impact: 8, risk: 7, complexity: 9, feasibility: 5, cost: 8, data: 6 },
      { application: "Space mission planning", impact: 7, risk: 6, complexity: 8, feasibility: 6, cost: 7, data: 5 }
    ];

    let scoreChart;

    function calculateScores() {
      const impactWeight = parseFloat(document.getElementById("impactWeight").value);
      const riskWeight = parseFloat(document.getElementById("riskWeight").value);
      const complexityWeight = parseFloat(document.getElementById("complexityWeight").value);
      const feasibilityWeight = parseFloat(document.getElementById("feasibilityWeight").value);
      const costWeight = parseFloat(document.getElementById("costWeight").value);
      const dataWeight = parseFloat(document.getElementById("dataWeight").value);

      const rankedApps = apps.map(app => {
        const finalScore =
          app.impact * impactWeight -
          app.risk * riskWeight -
          app.complexity * complexityWeight +
          app.feasibility * feasibilityWeight -
          app.cost * costWeight +
          app.data * dataWeight;

        return { ...app, finalScore };
      }).sort((a, b) => b.finalScore - a.finalScore);

      document.getElementById("recommendation").textContent = rankedApps[0].application;

      const tbody = document.querySelector("#resultsTable tbody");
      tbody.innerHTML = "";

      rankedApps.forEach((app, index) => {
        const row = document.createElement("tr");
        row.innerHTML = `
          <td>${index + 1}</td>
          <td>${app.application}</td>
          <td>${app.impact}</td>
          <td>${app.risk}</td>
          <td>${app.complexity}</td>
          <td>${app.feasibility}</td>
          <td>${app.cost}</td>
          <td>${app.data}</td>
          <td>${app.finalScore.toFixed(2)}</td>
        `;
        tbody.appendChild(row);
      });

      updateChart(rankedApps);
    }

    function updateChart(rankedApps) {
      const labels = rankedApps.map(app => app.application);
      const scores = rankedApps.map(app => app.finalScore.toFixed(2));

      if (scoreChart) {
        scoreChart.destroy();
      }

      const ctx = document.getElementById("scoreChart").getContext("2d");
      scoreChart = new Chart(ctx, {
        type: "bar",
        data: {
          labels,
          datasets: [{
            label: "Final Score",
            data: scores,
            backgroundColor: "rgba(59, 130, 246, 0.75)",
            borderColor: "rgba(147, 197, 253, 1)",
            borderWidth: 1
          }]
        },
        options: {
          responsive: true,
          plugins: {
            legend: {
              labels: { color: "#e5e7eb" }
            }
          },
          scales: {
            x: {
              ticks: { color: "#e5e7eb" },
              grid: { color: "#334155" }
            },
            y: {
              ticks: { color: "#e5e7eb" },
              grid: { color: "#334155" }
            }
          }
        }
      });
    }

    calculateScores();
  </script>
</body>
</html>
